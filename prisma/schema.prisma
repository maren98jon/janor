generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Household {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users              User[]
  storageLocations   StorageLocation[]
  foodCatalogItems   FoodCatalogItem[]
  inventoryItems     InventoryItem[]
  recipes            Recipe[]
  mealPlans          MealPlan[]
  shoppingLists      ShoppingList[]
  leftovers          Leftover[]
}

model User {
  id          String   @id @default(cuid())
  householdId String
  name        String
  email       String   @unique
  avatarUrl   String?
  preferences Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
}

model StorageLocation {
  id          String   @id @default(cuid())
  householdId String
  name        String
  type        String
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  household      Household       @relation(fields: [householdId], references: [id], onDelete: Cascade)
  inventoryItems InventoryItem[]

  @@index([householdId])
}

model FoodCatalogItem {
  id          String   @id @default(cuid())
  householdId String
  name        String
  defaultUnit String   @default("unit")
  category    String?
  barcode     String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  household          Household          @relation(fields: [householdId], references: [id], onDelete: Cascade)
  inventoryItems     InventoryItem[]
  recipeIngredients  RecipeIngredient[]
  shoppingListItems  ShoppingListItem[]

  @@index([householdId])
}

model InventoryItem {
  id                String   @id @default(cuid())
  householdId       String
  foodCatalogItemId String
  storageLocationId String
  quantity          Float    @default(1)
  unit              String   @default("unit")
  purchaseDate      DateTime?
  openedDate        DateTime?
  expirationDate    DateTime?
  status            String   @default("fresh")
  isFrozen          Boolean  @default(false)
  isLeftover        Boolean  @default(false)
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  household       Household       @relation(fields: [householdId], references: [id], onDelete: Cascade)
  foodCatalogItem FoodCatalogItem @relation(fields: [foodCatalogItemId], references: [id])
  storageLocation StorageLocation @relation(fields: [storageLocationId], references: [id])

  @@index([householdId])
  @@index([householdId, status])
  @@index([householdId, expirationDate])
  @@index([storageLocationId])
}

model Recipe {
  id              String   @id @default(cuid())
  householdId     String
  title           String
  description     String?
  servings        Int      @default(4)
  prepTimeMinutes Int      @default(0)
  cookTimeMinutes Int      @default(0)
  tags            String[]
  instructions    String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  household   Household          @relation(fields: [householdId], references: [id], onDelete: Cascade)
  ingredients RecipeIngredient[]
  mealEntries MealPlanEntry[]
  leftovers   Leftover[]

  @@index([householdId])
}

model RecipeIngredient {
  id                String  @id @default(cuid())
  recipeId          String
  foodCatalogItemId String?
  nameFallback      String
  quantity          Float   @default(1)
  unit              String  @default("unit")
  optional          Boolean @default(false)
  sortOrder         Int     @default(0)

  recipe          Recipe          @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  foodCatalogItem FoodCatalogItem? @relation(fields: [foodCatalogItemId], references: [id], onDelete: SetNull)

  @@index([recipeId])
}

model MealPlan {
  id            String   @id @default(cuid())
  householdId   String
  weekStartDate DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  household Household        @relation(fields: [householdId], references: [id], onDelete: Cascade)
  entries     MealPlanEntry[]

  @@index([householdId])
  @@unique([householdId, weekStartDate])
}

model MealPlanEntry {
  id         String   @id @default(cuid())
  mealPlanId String
  date       DateTime
  slot       String
  recipeId   String
  servings   Int      @default(4)
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  mealPlan MealPlan @relation(fields: [mealPlanId], references: [id], onDelete: Cascade)
  recipe   Recipe   @relation(fields: [recipeId], references: [id])

  @@index([mealPlanId])
  @@index([recipeId])
}

model ShoppingList {
  id          String   @id @default(cuid())
  householdId String
  name        String
  sourceType  String   @default("manual")
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  household Household         @relation(fields: [householdId], references: [id], onDelete: Cascade)
  items     ShoppingListItem[]

  @@index([householdId])
  @@index([householdId, status])
}

model ShoppingListItem {
  id                String   @id @default(cuid())
  shoppingListId    String
  foodCatalogItemId String?
  label             String
  quantity          Float    @default(1)
  unit              String   @default("unit")
  category          String?
  checked           Boolean  @default(false)
  sourceRecipeId    String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  shoppingList    ShoppingList    @relation(fields: [shoppingListId], references: [id], onDelete: Cascade)
  foodCatalogItem FoodCatalogItem? @relation(fields: [foodCatalogItemId], references: [id], onDelete: SetNull)

  @@index([shoppingListId])
}

model Leftover {
  id             String   @id @default(cuid())
  householdId    String
  sourceRecipeId String
  label          String
  quantity       Float    @default(1)
  unit           String   @default("unit")
  createdDate    DateTime @default(now())
  expirationDate DateTime
  notes          String?

  household    Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  sourceRecipe Recipe   @relation(fields: [sourceRecipeId], references: [id])

  @@index([householdId])
  @@index([householdId, expirationDate])
}
